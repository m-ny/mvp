# ── AI / LLM：团队「一把钥匙」────────────────────────────────────────
# 只填下面两项即可覆盖本仓库绝大部分 LLM 调用（config 会把 OPENROUTER_API_KEY 同步为 OPENAI_API_KEY）
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
# OpenRouter 模型 id；与 config.py 默认 openai/gpt-4o-mini 一致可写：
# DEFAULT_MODEL=openai/gpt-4o-mini
DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# 仅直连 Anthropic 官方 API 时需要（与上面二选一）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：显式把 Anthropic SDK 指到 OpenRouter（一般不必设）
# ANTHROPIC_API_BASE_URL=https://openrouter.ai/api/v1

# Module 4 First_Run：Bearer 用 OPENROUTER_API_KEY（旧名 DEEPSEEK_API_KEY 仍兼容）

# ── Brand (shared across all modules) ─────────────────────────────
# 须与 module1_brand_products.brand 一致（M5 读目录按此筛）。例：Tiffany & Co.
BRAND=Tiffany & Co.
DEFAULT_CITY=Shanghai

# Week 11 (Modules 1–3): set to 10+ to meet ≥10 trend cards after Module 3 filtering
M3_TOP_N=10

# ── Module 5 — trend read-only KB (short-term defaults) ───────────
# Cap how many trends enter the pipeline after load (default 15 if unset). Use 0 for no limit.
# M5_TREND_TOP_N=15
# Module 4 input：默认读取新表 module4_client_visits；如需旧 benchmark 表可设 memories
# M5_MODULE4_TABLE=visits
# 新 M4 visits 的 source；默认 module4_local_profile_json
# M5_MODULE4_VISITS_SOURCE=module4_local_profile_json
# Legacy only: M5_MODULE4_TABLE=memories 时用于 pin module4_client_memories.run_id
# M5_MODULE4_RUN_ID=bench_m4_20260330
# compact = trim evidence/metrics in prompt; full = pass full trend objects after Top-N
# M5_TREND_KB_MODE=compact
# 是否在 M5 prompt 中附带 module1_brand_products（当前 BRAND）；0 关闭
# M5_INCLUDE_BRAND_CATALOG=1
# 商品目录：1= RAG Top-K（默认）；0= 旧行为截断全量列表
# M5_CATALOG_RAG=1
# RAG 返回条数；嵌入走 OpenRouter /v1/embeddings
# M5_CATALOG_RAG_TOP_K=10
# M5_CATALOG_EMBED_MODEL=openai/text-embedding-3-small
# RAG 关闭时：最多写入 prompt 的 SKU 条数（0=不截断）
# M5_CATALOG_PROMPT_MAX=40
# System prompt：默认 module_5/system-prompt v2.1.md；可换其它文件
# M5_SYSTEM_PROMPT_PATH=module_5/system-prompt v2.1.md
# 去掉 FEW-SHOT 节（省约 1.5k–3k token，质量略降风险自行评估）
# M5_STRIP_FEWSHOT=1
# LLM 单次请求超时（秒，默认 75）。全量多客户时若网络挂起可快速失败并进入下一客户（需配合 agent 内 try/continue）。
# M5_LLM_TIMEOUT_SECONDS=75
# 离线跑 M5：联网时先 `python3 module_5/export_offline_snapshot.py`，再设下面路径（M2+M4+M1 从该 JSON 读，不读库）
# M5_OFFLINE_SNAPSHOT=module_5/_offline/m5_input_snapshot.json

# ── Supabase (PostgreSQL) ──────────────────────────────────────────
SUPABASE_PASSWORD=your_supabase_db_password_here
SUPABASE_HOST=aws-1-ap-northeast-1.pooler.supabase.com
SUPABASE_PORT=6543
SUPABASE_DB=postgres
SUPABASE_USER=postgres.krfdyudabrlmjixbdcxm
